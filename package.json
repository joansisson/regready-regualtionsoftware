{
  "name": "regready-local-pro",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/electron-main.cjs",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build:client": "vite build && node -e \"fs.copyFileSync('preload.cjs', 'dist/preload.cjs')\"",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js",
    "build:electron": "esbuild electron-main.cjs --platform=node --bundle --format=cjs --external:electron --outfile=dist/electron-main.cjs",
    "build": "npm run build:client && npm run build:server && npm run build:electron",
    "start": "node dist/index.js",
    "package": "npm run build && electron-builder --win --config.win.target=nsis",
    "electron:build": "npm run build && electron-builder --x64",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "build": {
    "appId": "com.regready.localpro",
    "productName": "RegReady Local Pro",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**/*",
      "dist/preload.cjs",
      "dist/preload.js",
      "dist/public/**/*",
      "package.json",
      "preload.cjs",
      "migrations/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/drizzle-orm/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "app.asar.unpacked/node_modules/better-sqlite3"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**/*",
      "migrations/**/*",
      "dist/public/**/*",
      "preload.cjs"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tanstack/react-query": "^5.60.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.5.1",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "framer-motion": "^11.13.1",
    "helmet": "^7.2.0",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.453.0",
    "pdfkit": "^0.16.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.8"
  }
}